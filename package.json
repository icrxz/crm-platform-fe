{
  "name": "crm-platform-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "reset": "npm run clean && npm run postclean",
    "clean": "rm -rf build node_modules package-lock.json && npm cache clean --force",
    "postclean": "npm i && npm run build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prettier": "prettier --write --ignore-unknown .",
    "prettier:check": "prettier --check --ignore-unknown .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1005.0",
    "@heroicons/react": "2.2.0",
    "@heroui/checkbox": "2.3.32",
    "@heroui/pagination": "2.2.27",
    "@heroui/react": "2.8.10",
    "@react-input/mask": "1.2.15",
    "@react-input/number-format": "1.1.3",
    "@tailwindcss/forms": "0.5.11",
    "@uppy/dashboard": "4.3.2",
    "@uppy/drag-drop": "4.1.1",
    "@uppy/file-input": "4.1.1",
    "@uppy/locales": "3.5.4",
    "@uppy/progress-bar": "4.2.1",
    "@uppy/react": "4.2.2",
    "@uppy/status-bar": "4.1.2",
    "bcrypt": "6.0.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "next": "14.2.35",
    "next-auth": "4.24.13",
    "next-nprogress-bar": "2.4.4",
    "postcss": "8.5.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-multi-carousel": "2.8.5",
    "sharp": "0.33.5",
    "tailwindcss": "4.2.1",
    "use-debounce": "10.0.4",
    "uuid": "11.0.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/bcrypt": "6.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "20.17.17",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/uuid": "10.0.0",
    "autoprefixer": "10.4.20",
    "dotenv": "16.4.5",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "16.3.3",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
